{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ES2022", "DOM", "DOM.Iterable"],
    "strict":            true,
    "noImplicitAny":     true,
    "strictNullChecks":  true,
    "esModuleInterop":   true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap":         true,
    "outDir":            "./dist",
    "rootDir":           "./src",
    "skipLibCheck":      true,
    "types":             ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "server"]
}
